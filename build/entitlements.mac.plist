<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow unsigned executable memory (required for Electron) -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow JIT compilation (required for V8/Chromium) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Network access for upload functionality -->
    <key>com.apple.security.network.client</key>
    <true/>

    <!-- Local server for desktop-hub communication -->
    <key>com.apple.security.network.server</key>
    <true/>

    <!-- File access for reading photos -->
    <key>com.apple.security.files.user-selected.read-write</key>
    <true/>
</dict>
</plist>
