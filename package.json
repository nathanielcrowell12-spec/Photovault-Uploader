{
  "name": "photovault-desktop",
  "version": "1.0.1",
  "description": "PhotoVault Desktop Helper - Upload large files reliably",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "concurrently \"tsc -w\" \"electron .\"",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -mwl",
    "icons": "icon-gen -i assets/icon.svg -o assets --ico --icns --ico-name icon --icns-name icon && node scripts/generate-png.js"
  },
  "keywords": [
    "photovault",
    "upload",
    "desktop"
  ],
  "author": "PhotoVault",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.2",
    "dotenv": "^16.4.7",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "jszip": "^3.10.1",
    "tus-js-client": "^4.2.3",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "concurrently": "^9.1.2",
    "electron": "30.0.0",
    "electron-builder": "^25.1.8",
    "icon-gen": "^5.0.0",
    "typescript": "^5.7.3"
  },
  "build": {
    "appId": "com.photovault.desktop",
    "productName": "PhotoVault Desktop",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "ui/**/*",
      "config.json",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.photography",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "assets/icon.png",
      "category": "Photography"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
